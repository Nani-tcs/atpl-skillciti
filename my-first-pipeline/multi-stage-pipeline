pipeline {
    agent any

    stages {

        stage('Backend') {
            agent {
                docker { image 'maven:3.9.14-adoptopenjdk-21' }
            }
            steps {
                sh 'mvn --version'
            }
        }

        stage('Frontend') {
            agent {
                docker { image 'node:16-alpine' }
            }
            steps {
                sh 'node --version'
            }
        }

    }
}
